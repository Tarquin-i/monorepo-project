{
  "references": [
    {
      "path": "./packages/db/"
    },
    {
      "path": "./apps/client/"
    },
    {
      "path": "./apps/server/"
    },
    {
      "path": "./packages/types/"
    }
  ],
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  }
}
